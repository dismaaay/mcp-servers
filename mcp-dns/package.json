{
  "name": "mcp-dns",
  "version": "1.0.0",
  "description": "DNS lookup MCP server using Cloudflare DNS-over-HTTPS (no API key required). Provides resolve and reverse DNS tools over the Model Context Protocol.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "dns",
    "dns-over-https",
    "doh",
    "cloudflare",
    "reverse-dns"
  ],
  "bin": {
    "mcp-dns": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "node smoke-test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
