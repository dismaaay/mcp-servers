{
  "name": "mcp-quotes",
  "version": "1.0.0",
  "description": "Model Context Protocol server for inspirational quotes. Exposes random_quote, search_quotes, and quotes_by_author tools backed by a live, key-free quotes API.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "quotes",
    "inspiration",
    "claude",
    "llm",
    "ai-tools"
  ],
  "bin": {
    "mcp-quotes": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "node smoke-test.mjs",
    "test": "npm run build && node smoke-test.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
