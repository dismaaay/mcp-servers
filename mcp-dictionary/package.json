{
  "name": "mcp-dictionary",
  "version": "1.0.0",
  "description": "Model Context Protocol server that wraps the Free Dictionary API. Exposes `define` and `synonyms` tools for any English word.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "dictionary",
    "definitions",
    "synonyms",
    "claude",
    "llm"
  ],
  "bin": {
    "mcp-dictionary": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "node smoke-test.mjs",
    "test": "npm run build && node smoke-test.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
