{
  "name": "mcp-dev-utils",
  "version": "1.0.0",
  "description": "Model Context Protocol server exposing common developer utilities: UUID generation, hashing, base64, JWT decode, and timestamp conversion. Pure local, no network.",
  "type": "module",
  "bin": {
    "mcp-dev-utils": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "node smoke-test.mjs",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "uuid",
    "hash",
    "base64",
    "jwt",
    "timestamp",
    "developer-tools"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
