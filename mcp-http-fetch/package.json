{
  "name": "mcp-http-fetch",
  "version": "1.0.0",
  "description": "An MCP server that performs HTTP requests (GET/POST) to any URL and fetches JSON — no API key required.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "http",
    "fetch",
    "rest",
    "json",
    "claude"
  ],
  "bin": {
    "mcp-http-fetch": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "smoke": "node smoke-test.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
