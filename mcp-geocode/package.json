{
  "name": "mcp-geocode",
  "version": "1.0.0",
  "description": "Geocoding MCP server wrapping OpenStreetMap Nominatim. Exposes geocode (address -> coordinates) and reverse (coordinates -> address) tools.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "geocoding",
    "nominatim",
    "openstreetmap",
    "reverse-geocoding"
  ],
  "bin": {
    "mcp-geocode": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "node smoke-test.mjs",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
