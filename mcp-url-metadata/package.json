{
  "name": "mcp-url-metadata",
  "version": "1.0.0",
  "description": "MCP server that fetches any URL and extracts its title, meta description, and OpenGraph tags. No API key required.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "url",
    "metadata",
    "opengraph",
    "og",
    "scraper",
    "link-preview"
  ],
  "bin": {
    "mcp-url-metadata": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "node smoke-test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
