{
  "name": "mcp-pokeapi",
  "version": "1.0.0",
  "description": "Model Context Protocol server for PokeAPI — look up Pokemon, types, and browse the Pokedex.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcp-pokeapi": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "smoke": "node smoke-test.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pokeapi",
    "pokemon",
    "pokedex",
    "llm",
    "claude"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
