{
  "name": "mcp-dockerhub",
  "version": "1.0.0",
  "description": "Model Context Protocol server for the Docker Hub public API. Inspect image repositories and list tags with no API key required.",
  "type": "module",
  "license": "MIT",
  "author": "mcp-catalog",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "docker",
    "docker-hub",
    "dockerhub",
    "containers",
    "claude"
  ],
  "bin": {
