{
  "name": "mcp-iss-tracker",
  "version": "1.0.0",
  "description": "MCP server for tracking the International Space Station: live position and the people currently in space. Wraps the free wheretheiss.at and Open Notify APIs (no API key required).",
  "type": "module",
  "bin": {
    "mcp-iss-tracker": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "smoke": "node smoke-test.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "iss",
    "space-station",
    "nasa",
    "open-notify",
    "wheretheiss",
    "satellite-tracking",
    "astronomy"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
