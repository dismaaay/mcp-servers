{
  "name": "mcp-countries",
  "version": "1.0.0",
  "description": "Model Context Protocol server for the REST Countries API. Look up country details, list countries by region, and resolve land borders.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcp-countries": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "node smoke-test.mjs",
    "prepare": "tsc"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "rest-countries",
    "countries",
    "geography",
    "claude"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
