{
  "name": "mcp-open-library",
  "version": "1.0.0",
  "description": "Model Context Protocol server for the Open Library API — search books, look up editions by ISBN, and list an author's works. No API key required.",
  "type": "module",
  "bin": {
    "mcp-open-library": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "node smoke-test.mjs",
    "prepare": "tsc"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "open-library",
    "books",
    "isbn",
    "llm",
    "claude"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
