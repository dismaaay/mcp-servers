{
  "name": "mcp-spacex",
  "version": "1.0.0",
  "description": "Model Context Protocol server for the SpaceX API (launches, rockets) — no API key required.",
  "type": "module",
  "license": "MIT",
  "author": "mcp-catalog",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "spacex",
    "rockets",
    "launches",
    "claude"
  ],
  "bin": {
    "mcp-spacex": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "node smoke-test.mjs",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
