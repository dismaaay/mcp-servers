{
  "name": "mcp-crates",
  "version": "1.0.0",
  "description": "Model Context Protocol server for the crates.io Rust package registry. Look up crate metadata and search crates from any MCP client.",
  "type": "module",
  "bin": {
    "mcp-crates": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "node smoke-test.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "crates.io",
    "rust",
    "cargo",
    "registry",
    "llm",
    "ai"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5"
  }
}
