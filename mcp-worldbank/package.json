{
  "name": "mcp-worldbank",
  "version": "1.0.0",
  "description": "Model Context Protocol server for the World Bank Indicators API — query development indicators, search the indicator catalog, and list countries. No API key required.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "world-bank",
    "indicators",
    "economics",
    "gdp",
    "data",
    "llm"
  ],
  "bin": {
    "mcp-worldbank": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "node smoke-test.mjs",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
