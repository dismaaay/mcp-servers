{
  "name": "mcp-hackernews",
  "version": "1.0.0",
  "description": "Model Context Protocol server for Hacker News — top stories, individual items, and full-text search via the Firebase and Algolia APIs.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcp-hackernews": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "smoke": "node smoke-test.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hacker-news",
    "hackernews",
    "hn",
    "llm",
    "claude"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
